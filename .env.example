# ---------------------------------------------------------------------------
# AI Brokerage OS — environment variables
# Copy this file to .env.local and fill in real values.
# ---------------------------------------------------------------------------

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser. (Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Embeddings (semantic search) ------------------------------------------
# Swappable adapter — see src/lib/ai/embeddings.ts
# Provider options: "openai" | "bge" (self-hosted)
AI_EMBEDDING_PROVIDER=openai
# Only needed when AI_EMBEDDING_PROVIDER=bge
BGE_EMBEDDING_URL=http://localhost:8080/embed

# --- Chat LLM (AI assistant + lead qualification) --------------------------
# Swappable adapter — see src/lib/ai/llm.ts
# Provider options: "openai" | "groq" (both OpenAI-compatible)
AI_LLM_PROVIDER=openai
# openai default: gpt-4o-mini   |   groq default: llama-3.3-70b-versatile
LLM_MODEL=gpt-4o-mini

# --- API keys ---------------------------------------------------------------
# Used by BOTH embeddings (openai) and chat (openai). Leave blank to run the
# app without AI; search falls back to keyword-only and the assistant is off.
OPENAI_API_KEY=
# Only needed when AI_LLM_PROVIDER=groq (free tier available)
GROQ_API_KEY=

# --- WhatsApp Cloud API (Milestone 5) --------------------------------------
# From Meta: WhatsApp > API Setup. Token & phone id are SERVER-ONLY.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# A random string you invent; paste the same value in Meta webhook config.
WHATSAPP_VERIFY_TOKEN=
# Optional: Graph API version (defaults to v21.0)
WHATSAPP_GRAPH_VERSION=v21.0
# Set to "false" to disable automatic AI replies to inbound WhatsApp messages.
WHATSAPP_AUTO_REPLY=true

# --- Automation / Cron (Milestone 6) ---------------------------------------
# Protects /api/cron/follow-ups. On Vercel Cron this is sent automatically.
CRON_SECRET=

# --- Call transcription (Whisper, optional) --------------------------------
# Uses OPENAI_API_KEY above. Override the model if needed.
WHISPER_MODEL=whisper-1

# Public site URL (used for auth redirects + WhatsApp webhook URL display)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
